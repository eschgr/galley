#!/bin/sh
# macOS .pkg postinstall (issue #42): put a `galley` command on PATH so a shell —
# or an LLM driving Galley — can run `galley <file>` without locating the .app.
#
# Runs as root after the .pkg installs Galley.app to /Applications (a fixed path,
# so unlike the Windows Squirrel shim this never needs refreshing across updates).
set -e

mkdir -p /usr/local/bin
LAUNCHER=/usr/local/bin/galley

cat > "$LAUNCHER" <<'GALLEY'
#!/bin/sh
# Launch a FRESH Galley per call so it self-arbitrates — claims the project or
# hands its files off (PRD §5.3) — detached so the calling shell returns and the
# window survives. Deliberately not launched via `open`/LaunchServices, whose
# Apple-Event delivery is blocked in the sandbox this design targets (#49).
nohup "/Applications/Galley.app/Contents/MacOS/Galley" "$@" >/dev/null 2>&1 &
GALLEY

chmod 755 "$LAUNCHER"
exit 0
